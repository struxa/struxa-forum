{% extends 'layouts/base.twig' %}

{% set _tag_url   = site_url ~ '/forum/tag/' ~ forum_tag.slug %}
{% set _tag_url_p = forum_page > 1 ? _tag_url ~ '?page=' ~ forum_page : _tag_url %}
{% set _seo_title = 'Tagged "' ~ forum_tag.name ~ '"' %}
{% set _site = settings.site_name|default('Community') %}
{% set _seo_desc  = meta_description|default('Forum threads tagged ' ~ forum_tag.name ~ '.') %}

{% block title %}{{ _seo_title|e }} — Forum — {{ _site|e }}{% endblock %}
{% block meta_description %}{{ _seo_desc|e }}{% endblock %}
{% block canonical_href %}{{ _tag_url_p|e('html_attr') }}{% endblock %}
{% block og_title %}{{ _seo_title|e }}{% endblock %}
{% block og_description %}{{ _seo_desc|e }}{% endblock %}
{% block twitter_title %}{{ _seo_title|e }}{% endblock %}
{% block twitter_description %}{{ _seo_desc|e }}{% endblock %}

{% block meta_extra %}
  {{ parent() }}
  {% include '@plugin_forum_plugin/public/_seo_head.twig' with {
    canonical:      _tag_url_p,
    robots:         forum_page > 1 ? 'noindex,follow' : 'index,follow',
    prev_url:       forum_page > 1 ? (_tag_url ~ '?page=' ~ (forum_page - 1)) : null,
    next_url:       forum_page < forum_total_pages ? (_tag_url ~ '?page=' ~ (forum_page + 1)) : null,
    og_title:       _seo_title,
    og_description: _seo_desc,
    jsonld: [
      {
        '@context': 'https://schema.org',
        '@type':    'BreadcrumbList',
        'itemListElement': [
          { '@type': 'ListItem', position: 1, name: 'Home',           item: site_url ~ '/' },
          { '@type': 'ListItem', position: 2, name: 'Forum',          item: site_url ~ '/forum' },
          { '@type': 'ListItem', position: 3, name: _seo_title,       item: _tag_url }
        ]
      },
      {
        '@context': 'https://schema.org',
        '@type':    'CollectionPage',
        'name':     _seo_title,
        'description': _seo_desc,
        'url':      _tag_url_p,
        'keywords': forum_tag.name
      }
    ]
  } only %}
{% endblock %}

{% block head_extra %}
  <link rel="stylesheet" href="{{ forum_asset('css/forum.css') }}" />
{% endblock %}

{% block body %}
  <main class="forum-page" id="content">

    <header class="forum-hero forum-hero--narrow">
      <div class="forum-shell">
        <nav class="forum-crumbs">
          <a href="/forum">Forum</a>
          <span aria-hidden="true">/</span>
          <span>Tag</span>
        </nav>
        <h1>
          <i class="fa-solid fa-hashtag" aria-hidden="true"></i>
          {{ forum_tag.name|e }}
        </h1>
        <p class="forum-hero-sub">
          <strong>{{ forum_total|number_format }}</strong> thread{{ forum_total == 1 ? '' : 's' }} tagged
          <code>#{{ forum_tag.slug|e }}</code>
        </p>
      </div>
    </header>

    <div class="forum-shell forum-shell--wide forum-layout">
      <div class="forum-main">

        {% include '@plugin_forum_plugin/partials/_flash.twig' ignore missing %}

        <section class="forum-card forum-card--threads">
          <ul class="forum-threads">
            {% for t in forum_threads %}
              {% set _author = t.author_user_id ? forum_users_by_id[t.author_user_id]|default(null) : null %}
              {% set _last = t.last_poster_id ? forum_users_by_id[t.last_poster_id]|default(null) : null %}
              <li class="forum-thread-row{{ t.is_sticky ? ' is-sticky' : '' }}{{ t.is_locked ? ' is-locked' : '' }}">
                {% if _author %}
                  <img class="forum-thread-avatar" src="{{ _author.avatar|e('html_attr') }}" alt="" loading="lazy" width="44" height="44" />
                {% else %}
                  <div class="forum-thread-avatar forum-thread-avatar--placeholder"><i class="fa-solid fa-user" aria-hidden="true"></i></div>
                {% endif %}
                <div class="forum-thread-main">
                  <div class="forum-thread-flags">
                    {% if t.is_sticky %}<span class="forum-pill forum-pill--sticky"><i class="fa-solid fa-thumbtack" aria-hidden="true"></i> Pinned</span>{% endif %}
                    {% if t.is_locked %}<span class="forum-pill forum-pill--locked"><i class="fa-solid fa-lock" aria-hidden="true"></i> Locked</span>{% endif %}
                  </div>
                  <a class="forum-thread-title" href="/forum/{{ t.forum_slug|e('html_attr') }}/{{ t.slug|e('html_attr') }}">{{ t.title|e }}</a>
                  {% include '@plugin_forum_plugin/public/_thread_page_links.twig' with {
                    thread_url: '/forum/' ~ t.forum_slug ~ '/' ~ t.slug,
                    replies_count: t.replies_count,
                    posts_per_page: forum_posts_per_page|default(15),
                  } only %}
                  <p class="forum-thread-meta">
                    <span>in <strong>{{ t.forum_name|e }}</strong></span>
                    <span class="forum-dot" aria-hidden="true">·</span>
                    <span>by <strong>{{ _author ? _author.display_name|e : 'Unknown' }}</strong></span>
                    <span class="forum-dot" aria-hidden="true">·</span>
                    <span>{{ forum_relative_time(t.created_at) }}</span>
                  </p>
                </div>
                <div class="forum-thread-stats">
                  <span><i class="fa-regular fa-comment" aria-hidden="true"></i> <strong>{{ t.replies_count|number_format }}</strong></span>
                  <span><i class="fa-regular fa-eye" aria-hidden="true"></i> <strong>{{ t.views_count|number_format }}</strong></span>
                </div>
                <div class="forum-thread-last">
                  {% if _last %}
                    <img class="forum-thread-last-avatar" src="{{ _last.avatar|e('html_attr') }}" alt="" loading="lazy" width="28" height="28" />
                    <div>
                      <p class="forum-thread-last-name">{{ _last.display_name|e }}</p>
                      <p class="forum-thread-last-time">{{ forum_relative_time(t.last_post_at ?? t.created_at) }}</p>
                    </div>
                  {% else %}
                    <p class="forum-thread-last-time">{{ forum_relative_time(t.last_post_at ?? t.created_at) }}</p>
                  {% endif %}
                </div>
              </li>
            {% else %}
              <li class="forum-thread-row forum-thread-row--empty">
                No threads carry this tag yet.
              </li>
            {% endfor %}
          </ul>
        </section>

        {% set _tag_url = site_url ~ '/forum/tag/' ~ forum_tag.slug %}
        {% include '@plugin_forum_plugin/public/_pager.twig' with {
          base_url: _tag_url,
          page: forum_page,
          total_pages: forum_total_pages,
          aria_label: 'Tagged threads pagination',
        } only %}
      </div>

      {% include '@plugin_forum_plugin/widgets/sidebar.twig' %}
    </div>
  </main>
{% endblock %}
