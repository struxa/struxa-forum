{# =======================================================================
   Forum share strip.
   Caller passes:
     url    : full absolute URL to share (required, must already be encoded
              with site_url for the host — we url_encode further for query
              strings, never assume client-side escaping)
     title  : human title used as the share text / subject (required)
     text   : optional extra context (e.g. first line of the post). Falls
              back to title when missing.
     variant: 'bar' (default, large horizontal strip) or 'menu' (compact
              popover content for per-post share buttons).

   We deliberately ship plain anchor links so the share targets keep working
   even when JavaScript is disabled. The JS layer adds a "Copy link" button
   on top (via [data-share-copy]) and intercepts X/FB clicks to open a
   centred popup window — but every link is a real href first.
   ======================================================================= #}
{% set _variant     = variant|default('bar') %}
{% set _share_text  = text|default(title) %}
{% set _enc_url     = url|url_encode %}
{% set _enc_title   = title|url_encode %}
{% set _enc_text    = _share_text|url_encode %}
{% set _enc_combo   = (_share_text ~ ' — ' ~ url)|url_encode %}
{% set _enc_email_subject = ('Worth a read: ' ~ title)|url_encode %}
{% set _enc_email_body    = (_share_text ~ "\n\n" ~ url)|url_encode %}

<div class="forum-share forum-share--{{ _variant|e('html_attr') }}" data-share-strip data-share-url="{{ url|e('html_attr') }}" data-share-title="{{ title|e('html_attr') }}">
  {% if _variant == 'bar' %}
    <p class="forum-share-label">
      <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
      Share
    </p>
  {% else %}
    <p class="forum-share-menu-head">
      <span class="forum-share-menu-title">Share this post</span>
      <span class="forum-share-menu-sub">to your favourite app</span>
    </p>
  {% endif %}

  <ul class="forum-share-list" role="list">
    <li>
      <a class="forum-share-btn forum-share-btn--x"
         href="https://twitter.com/intent/tweet?url={{ _enc_url }}&amp;text={{ _enc_text }}"
         rel="noopener nofollow"
         target="_blank"
         data-share-popup
         aria-label="Share on X (Twitter)">
        <i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
        <span class="forum-share-btn-label">X</span>
      </a>
    </li>
    <li>
      <a class="forum-share-btn forum-share-btn--facebook"
         href="https://www.facebook.com/sharer/sharer.php?u={{ _enc_url }}"
         rel="noopener nofollow"
         target="_blank"
         data-share-popup
         aria-label="Share on Facebook">
        <i class="fa-brands fa-facebook-f" aria-hidden="true"></i>
        <span class="forum-share-btn-label">Facebook</span>
      </a>
    </li>
    <li>
      <a class="forum-share-btn forum-share-btn--linkedin"
         href="https://www.linkedin.com/sharing/share-offsite/?url={{ _enc_url }}"
         rel="noopener nofollow"
         target="_blank"
         data-share-popup
         aria-label="Share on LinkedIn">
        <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
        <span class="forum-share-btn-label">LinkedIn</span>
      </a>
    </li>
    <li>
      <a class="forum-share-btn forum-share-btn--reddit"
         href="https://www.reddit.com/submit?url={{ _enc_url }}&amp;title={{ _enc_title }}"
         rel="noopener nofollow"
         target="_blank"
         data-share-popup
         aria-label="Share on Reddit">
        <i class="fa-brands fa-reddit-alien" aria-hidden="true"></i>
        <span class="forum-share-btn-label">Reddit</span>
      </a>
    </li>
    <li>
      <a class="forum-share-btn forum-share-btn--whatsapp"
         href="https://wa.me/?text={{ _enc_combo }}"
         rel="noopener nofollow"
         target="_blank"
         data-share-popup
         aria-label="Share on WhatsApp">
        <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
        <span class="forum-share-btn-label">WhatsApp</span>
      </a>
    </li>
    <li>
      <a class="forum-share-btn forum-share-btn--telegram"
         href="https://t.me/share/url?url={{ _enc_url }}&amp;text={{ _enc_text }}"
         rel="noopener nofollow"
         target="_blank"
         data-share-popup
         aria-label="Share on Telegram">
        <i class="fa-brands fa-telegram" aria-hidden="true"></i>
        <span class="forum-share-btn-label">Telegram</span>
      </a>
    </li>
    <li>
      <a class="forum-share-btn forum-share-btn--email"
         href="mailto:?subject={{ _enc_email_subject }}&amp;body={{ _enc_email_body }}"
         aria-label="Share by email">
        <i class="fa-solid fa-envelope" aria-hidden="true"></i>
        <span class="forum-share-btn-label">Email</span>
      </a>
    </li>
    <li>
      {# JS attaches navigator.clipboard.writeText() to this and flips the
         label to "Copied ✓" for 2s. We expose `aria-live` so screen-reader
         users get feedback. Always-degrades-gracefully: without JS the link
         is a self-anchor that does nothing harmful. #}
      <button type="button"
              class="forum-share-btn forum-share-btn--copy"
              data-share-copy
              data-share-target="{{ url|e('html_attr') }}"
              aria-label="Copy link to clipboard">
        <i class="fa-solid fa-link" aria-hidden="true"></i>
        <span class="forum-share-btn-label" aria-live="polite">Copy link</span>
      </button>
    </li>
  </ul>
</div>
