{% extends 'admin/base.twig' %}

{% block admin_title %}{{ is_new ? 'New' : 'Edit' }} forum{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ is_new ? 'New forum' : 'Edit forum' }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Discussion sections live inside a category. Use the <em>Parent forum</em> field to create sub-forums.</p>
{% endblock %}

{% block admin_hero_actions %}
  <a class="admin-btn-secondary" href="{{ url_for('plugin.forum.admin.forums') }}">Cancel</a>
{% endblock %}

{% block admin_content %}
  <section class="admin-section">
    <form class="admin-form" method="post"
          action="{{ is_new ? url_for('plugin.forum.admin.forums.new') : url_for('plugin.forum.admin.forums.edit', { id: forum.id }) }}"
          enctype="multipart/form-data">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />

      <div class="admin-field">
        <label class="admin-label" for="f-name">Name *</label>
        <input class="admin-input" id="f-name" name="name" type="text" required maxlength="191"
               value="{{ forum.name|e('html_attr') }}" placeholder="e.g. Redemptions" />
      </div>

      <div class="admin-field">
        <label class="admin-label" for="f-slug">Slug</label>
        <input class="admin-input" id="f-slug" name="slug" type="text" maxlength="191"
               value="{{ forum.slug|e('html_attr') }}" placeholder="auto-generated from name if empty" />
        <p class="admin-hint">Lowercase, dash-separated. Used in URLs: <code>/forum/&lt;slug&gt;</code>.</p>
      </div>

      <div class="admin-field admin-field--inline">
        <div style="flex:1 1 280px;">
          <label class="admin-label" for="f-cat">Category *</label>
          <select class="admin-input" id="f-cat" name="category_id" required>
            <option value="">Select a category…</option>
            {% for c in forum_categories %}
              <option value="{{ c.id }}" {{ forum.category_id == c.id ? 'selected' : '' }}>{{ c.name|e }}</option>
            {% endfor %}
          </select>
        </div>
        <div style="flex:1 1 280px;">
          <label class="admin-label" for="f-parent">Parent forum (for sub-forums)</label>
          <select class="admin-input" id="f-parent" name="parent_id">
            <option value="">— None (top-level) —</option>
            {% for pf in forum_forums %}
              {% if pf.id != forum.id %}
                <option value="{{ pf.id }}" {{ forum.parent_id == pf.id ? 'selected' : '' }}>{{ pf.name|e }} ({{ pf.category.name|e }})</option>
              {% endif %}
            {% endfor %}
          </select>
        </div>
      </div>

      <div class="admin-field">
        <label class="admin-label" for="f-desc">Description</label>
        <textarea class="admin-input" id="f-desc" name="description" rows="3" maxlength="2000"
                  placeholder="Optional one-line description shown under the forum name.">{{ forum.description|default('')|e }}</textarea>
      </div>

      <div class="admin-field admin-field--inline">
        <div style="flex:0 1 220px;">
          <label class="admin-label" for="f-icon">Icon (FontAwesome name)</label>
          <input class="admin-input" id="f-icon" name="icon" type="text" maxlength="80"
                 value="{{ forum.icon|default('')|e('html_attr') }}" placeholder="e.g. plane-departure" />
          <p class="admin-hint">Fallback glyph. Used when no image icon is set.</p>
        </div>
        <div style="flex:0 1 120px;">
          <label class="admin-label" for="f-sort">Sort order</label>
          <input class="admin-input" id="f-sort" name="sort_order" type="number" min="0" value="{{ forum.sort_order|default(10) }}" />
        </div>
      </div>

      <div class="admin-field">
        <label class="admin-label">Custom icon image</label>
        <div class="forum-admin-icon-editor">
          <div class="forum-admin-icon-editor-preview">
            {% if forum.icon_image %}
              <img src="{{ forum.icon_image|e('html_attr') }}" alt="Current icon for {{ forum.name|default('forum')|e('html_attr') }}" />
            {% else %}
              <span class="forum-admin-icon-editor-empty" aria-hidden="true">
                <i class="fa-solid fa-image"></i>
              </span>
            {% endif %}
          </div>
          <div class="forum-admin-icon-editor-controls">
            <label class="admin-label" for="f-icon-upload" style="font-weight:600;">Upload an image</label>
            <input class="admin-input" id="f-icon-upload" name="icon_image_file" type="file"
                   accept="image/png,image/jpeg,image/webp,image/svg+xml,image/gif" />
            <p class="admin-hint">PNG, JPG, WEBP, GIF or SVG. Max 2&nbsp;MB. Square images render best (160×160 ideal).</p>

            <label class="admin-label" for="f-icon-url" style="font-weight:600;margin-top:10px;">Or paste an image URL</label>
            <input class="admin-input" id="f-icon-url" name="icon_image_url" type="text" maxlength="500"
                   value="{{ forum.icon_image|default('')|e('html_attr') }}"
                   placeholder="https://… or /uploads/forum/icons/your-image.png" />
            <p class="admin-hint">Used if no file is uploaded above. Leave blank to keep the current image.</p>

            {% if forum.icon_image %}
              <label class="admin-label" style="font-weight:600;margin-top:10px;">
                <input type="checkbox" name="icon_image_remove" value="1" />
                Remove current icon image (revert to FontAwesome glyph)
              </label>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="admin-field admin-field--inline">
        <label class="admin-label">
          <input type="checkbox" name="is_locked" value="1" {{ forum.is_locked ? 'checked' : '' }} /> Locked (no new threads)
        </label>
        <label class="admin-label" style="margin-left:18px;">
          <input type="checkbox" name="is_hidden" value="1" {{ forum.is_hidden ? 'checked' : '' }} /> Hide from public
        </label>
      </div>

      <div class="admin-field admin-field--inline" style="align-self:end;">
        <button class="admin-btn-primary" type="submit">{{ is_new ? 'Create forum' : 'Save changes' }}</button>
        <a class="admin-btn-secondary" href="{{ url_for('plugin.forum.admin.forums') }}">Cancel</a>
      </div>
    </form>
  </section>
{% endblock %}
