{% extends 'admin/base.twig' %}

{% block admin_title %}Threads · moderation{% endblock %}

{# Plugin-owned admin CSS (cache-busted via forum_asset()). Lives in the
   plugin so CMS self-updates can't clobber it. #}
{% block admin_head %}
  <link rel="stylesheet" href="{{ forum_asset('css/forum-admin.css') }}" />
{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Threads</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    {% if forum_total is defined %}
      {{ forum_total|number_format }} thread{{ forum_total == 1 ? '' : 's' }} match — sticky/lock, move between forums, soft-delete spam.
    {% else %}
      Search across every forum, toggle <strong>Sticky</strong> / <strong>Locked</strong>, and soft-delete spam.
    {% endif %}
  </p>
{% endblock %}

{% block admin_hero_actions %}
  <a class="admin-btn-primary" href="{{ url_for('plugin.forum.admin.posts') }}">
    <i class="fa-regular fa-comment-dots" aria-hidden="true"></i> Posts
  </a>
  <a class="admin-btn-secondary" href="{{ url_for('plugin.forum.admin.dashboard') }}">
    <i class="fa-solid fa-gauge-high" aria-hidden="true"></i> Dashboard
  </a>
{% endblock %}

{% block admin_content %}
  {% set _filter = forum_filter|default({ q: '', forum_id: 0, status: '' }) %}
  {% set _status = _filter.status %}

  {# ----------------------------------------------------------------
     Filter rail — search by title/slug + forum picker.
     Status is set by the pill tabs below (kept here as hidden input).
     ---------------------------------------------------------------- #}
  <section class="admin-section">
    <form class="forum-admin-postbar" method="get" action="{{ url_for('plugin.forum.admin.threads') }}">
      <div class="forum-admin-postbar-search">
        <label class="admin-label" for="th-q">Search</label>
        <input class="admin-input" id="th-q" name="q" type="search"
               value="{{ _filter.q|e('html_attr') }}"
               placeholder="Thread title or slug…" maxlength="80" />
      </div>

      <div>
        <label class="admin-label" for="th-forum">Forum</label>
        <select class="admin-input" id="th-forum" name="forum_id">
          <option value="0">All forums</option>
          {% for f in forum_forums|default([]) %}
            <option value="{{ f.id }}" {{ _filter.forum_id == f.id ? 'selected' : '' }}>
              {{ f.name|e }}{% if f.category.name is defined %} · {{ f.category.name|e }}{% endif %}
            </option>
          {% endfor %}
        </select>
      </div>

      <input type="hidden" name="status" value="{{ _status|e('html_attr') }}" />

      <div class="forum-admin-postbar-actions">
        <button class="admin-btn-primary" type="submit">
          <i class="fa-solid fa-filter" aria-hidden="true"></i> Filter
        </button>
        <a class="admin-btn-secondary" href="{{ url_for('plugin.forum.admin.threads') }}">Reset</a>
      </div>
    </form>

    {# Status tabs — each preserves the user's search/forum picks. #}
    {% set _qs = { q: _filter.q, forum_id: _filter.forum_id } %}
    <nav class="forum-admin-tabs" aria-label="Status filter">
      {% set _tabs = [
        { id: '',        label: 'Active',  icon: 'fa-circle-check', cls: '' },
        { id: 'sticky',  label: 'Sticky',  icon: 'fa-star',         cls: '' },
        { id: 'locked',  label: 'Locked',  icon: 'fa-lock',         cls: '' },
        { id: 'deleted', label: 'Deleted', icon: 'fa-trash',        cls: '' },
        { id: 'all',     label: 'All',     icon: 'fa-layer-group',  cls: '' }
      ] %}
      {% for t in _tabs %}
        {% set _active = _status == t.id %}
        <a class="forum-admin-tab {{ _active ? 'forum-admin-tab--active' : '' }}"
           href="{{ url_for('plugin.forum.admin.threads') }}?{{ _qs|merge({ status: t.id })|url_encode }}">
          <i class="fa-solid {{ t.icon }}" aria-hidden="true"></i>
          {{ t.label }}
          {% if _active and forum_total is defined %}
            <span class="forum-admin-tab-count">{{ forum_total }}</span>
          {% endif %}
        </a>
      {% endfor %}
    </nav>
  </section>

  <section class="admin-section">
    {% if forum_threads|length == 0 %}
      <div class="forum-admin-postempty">
        <i class="fa-regular fa-folder-open" aria-hidden="true"></i>
        <p style="margin: 0;">
          No threads match this filter.
          {% if _filter.q or _filter.forum_id %}
            Try <a class="admin-link" href="{{ url_for('plugin.forum.admin.threads') }}">resetting</a>.
          {% endif %}
        </p>
      </div>
    {% else %}
      <ol class="forum-admin-postlist" style="list-style:none;padding:0;margin:0;">
        {% for t in forum_threads %}
          {% set _u = t.author_user_id ? users_by_id[t.author_user_id]|default(null) : null %}
          {% set _initial = _u ? _u.display_name|slice(0,1)|upper : '?' %}
          {% set _classes = ['forum-admin-postcard', 'forum-admin-threadcard'] %}
          {% if t.is_deleted %}{% set _classes = _classes|merge(['forum-admin-postcard--deleted']) %}{% endif %}
          {% if t.is_sticky %}{% set _classes = _classes|merge(['forum-admin-threadcard--sticky']) %}{% endif %}
          {% if t.is_locked %}{% set _classes = _classes|merge(['forum-admin-threadcard--locked']) %}{% endif %}

          <li class="{{ _classes|join(' ') }}">
            <div class="forum-admin-postcard-avatar" aria-hidden="true">
              {% if _u and _u.avatar is defined and _u.avatar %}
                <img src="{{ _u.avatar|e('html_attr') }}" alt="" loading="lazy" />
              {% else %}
                {{ _initial }}
              {% endif %}
            </div>

            <div class="forum-admin-postcard-body">
              <div class="forum-admin-postcard-head">
                <a class="forum-admin-threadcard-title"
                   href="{{ site_url }}/forum/{{ t.forum_slug|e('html_attr') }}/{{ t.slug|e('html_attr') }}"
                   target="_blank" rel="noopener">
                  {{ t.title|e }}
                  <i class="fa-solid fa-arrow-up-right-from-square forum-admin-threadcard-title-icon" aria-hidden="true"></i>
                </a>

                {% if t.is_sticky %}
                  <span class="forum-admin-postcard-badge forum-admin-threadcard-badge--sticky" title="Sticky thread">
                    <i class="fa-solid fa-star" aria-hidden="true"></i> Sticky
                  </span>
                {% endif %}
                {% if t.is_locked %}
                  <span class="forum-admin-postcard-badge forum-admin-threadcard-badge--locked" title="Locked — no new replies">
                    <i class="fa-solid fa-lock" aria-hidden="true"></i> Locked
                  </span>
                {% endif %}
                {% if t.is_deleted %}
                  <span class="forum-admin-postcard-badge forum-admin-postcard-badge--deleted">
                    <i class="fa-solid fa-trash" aria-hidden="true"></i> Deleted
                  </span>
                {% endif %}
              </div>

              <div class="forum-admin-postcard-meta">
                {% if _u %}
                  <i class="fa-solid fa-user" aria-hidden="true"></i>
                  <strong style="color: var(--admin-text);">{{ _u.display_name|e }}</strong>
                {% else %}
                  <i class="fa-solid fa-user-slash" aria-hidden="true" style="opacity:.6;"></i>
                  <em style="opacity:.7;">Unknown user</em>
                {% endif %}
                <span class="forum-admin-postcard-dot">·</span>
                <i class="fa-regular fa-clock" aria-hidden="true"></i>
                {{ forum_relative_time(t.last_post_at ?? t.created_at) }}
                <span class="forum-admin-postcard-dot">·</span>
                <i class="fa-solid fa-hashtag" aria-hidden="true" style="opacity:0.6;"></i>
                {{ t.forum_name|default('—')|e }}
              </div>

              <div class="forum-admin-threadcard-stats">
                <span class="forum-admin-threadcard-stat" title="Replies">
                  <i class="fa-regular fa-comments" aria-hidden="true"></i>
                  <strong>{{ t.replies_count|number_format }}</strong>
                  <span class="forum-admin-threadcard-stat-label">replies</span>
                </span>
                <span class="forum-admin-threadcard-stat" title="Likes">
                  <i class="fa-solid fa-heart" aria-hidden="true"></i>
                  <strong>{{ t.likes_count|number_format }}</strong>
                  <span class="forum-admin-threadcard-stat-label">likes</span>
                </span>
                {% if t.views_count is defined %}
                  <span class="forum-admin-threadcard-stat" title="Views">
                    <i class="fa-regular fa-eye" aria-hidden="true"></i>
                    <strong>{{ t.views_count|number_format }}</strong>
                    <span class="forum-admin-threadcard-stat-label">views</span>
                  </span>
                {% endif %}
              </div>
            </div>

            <div class="forum-admin-postcard-actions">
              {# Move row — inline forum picker. #}
              <form method="post" action="/admin/forum/threads/{{ t.id }}/move" class="forum-admin-threadcard-move">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                <select name="destination_forum_id" class="forum-admin-threadcard-move-select" aria-label="Move to forum">
                  {% for f in forum_forums %}
                    <option value="{{ f.id }}" {{ f.id == t.forum_id ? 'selected' : '' }}>{{ f.name|e }}</option>
                  {% endfor %}
                </select>
                <button type="submit" class="forum-admin-postcard-act" title="Move thread to selected forum">
                  <i class="fa-solid fa-right-left" aria-hidden="true"></i> Move
                </button>
              </form>

              {# Toggle row — sticky + lock are two icon buttons sharing a row. #}
              <div class="forum-admin-threadcard-toggles">
                <form method="post" action="/admin/forum/threads/{{ t.id }}/flag">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                  <input type="hidden" name="is_sticky" value="{{ t.is_sticky ? 0 : 1 }}" />
                  <button class="forum-admin-postcard-act forum-admin-threadcard-toggle {{ t.is_sticky ? 'is-active forum-admin-threadcard-toggle--sticky' : '' }}"
                          type="submit"
                          title="{{ t.is_sticky ? 'Remove sticky' : 'Make sticky' }}">
                    <i class="fa-solid fa-star" aria-hidden="true"></i>
                  </button>
                </form>
                <form method="post" action="/admin/forum/threads/{{ t.id }}/flag">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                  <input type="hidden" name="is_locked" value="{{ t.is_locked ? 0 : 1 }}" />
                  <button class="forum-admin-postcard-act forum-admin-threadcard-toggle {{ t.is_locked ? 'is-active forum-admin-threadcard-toggle--locked' : '' }}"
                          type="submit"
                          title="{{ t.is_locked ? 'Unlock thread' : 'Lock thread' }}">
                    <i class="fa-solid fa-lock" aria-hidden="true"></i>
                  </button>
                </form>
              </div>

              {# Delete / restore row. #}
              {% if t.is_deleted %}
                <form method="post" action="/admin/forum/threads/{{ t.id }}/flag">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                  <input type="hidden" name="is_deleted" value="0" />
                  <button class="forum-admin-postcard-act forum-admin-postcard-act--success" type="submit">
                    <i class="fa-solid fa-rotate-left" aria-hidden="true"></i> Restore
                  </button>
                </form>
              {% else %}
                <form method="post" action="/admin/forum/threads/{{ t.id }}/flag"
                      onsubmit="return confirm('Soft-delete this thread and all replies? They can be restored from the Deleted tab.');">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                  <input type="hidden" name="is_deleted" value="1" />
                  <button class="forum-admin-postcard-act forum-admin-postcard-act--danger" type="submit">
                    <i class="fa-solid fa-trash" aria-hidden="true"></i> Delete
                  </button>
                </form>
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ol>

      {# Numbered pagination — shared partial; preserves every current filter
         on each page link via the `query` argument. Auto-hides when there
         is only one page. #}
      {% include '@plugin_forum_plugin/admin/_pager.twig' with {
        page:       forum_page|default(1),
        pages:      forum_pages|default(1),
        total:      forum_total|default(0),
        route_name: 'plugin.forum.admin.threads',
        query:      _qs|merge({ status: _status }),
        label_one:  'thread',
        label_many: 'threads'
      } only %}
    {% endif %}
  </section>
{% endblock %}
